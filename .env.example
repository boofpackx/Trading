# Copy to .env and fill in to trade live on TopstepX (ProjectX Gateway API).
# Leave blank to run in built-in simulation mode.
PROJECTX_USERNAME=
PROJECTX_API_KEY=
PROJECTX_API_URL=https://api.topstepx.com
# Optional: pin a specific account id; otherwise the first active account is used.
PROJECTX_ACCOUNT_ID=

# sim | live
BOT_MODE=sim
